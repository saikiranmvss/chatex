# MySQL (production: use dedicated user, not root)
DATABASE_URL=mysql://chatex:password@127.0.0.1:3306/chatex

# API server (must match APP_PORT on server — default 5100)
PORT=5100
SESSION_SECRET=change-me-in-production-min-32-chars
NODE_ENV=development
LOG_LEVEL=info

# Frontend (Vite build — CI sets BASE_PATH from APP_BASE_PATH secret)
# Production path mode: BASE_PATH=/chatex/
# Production domain mode: BASE_PATH=/
BASE_PATH=/
VITE_PORT=5173
